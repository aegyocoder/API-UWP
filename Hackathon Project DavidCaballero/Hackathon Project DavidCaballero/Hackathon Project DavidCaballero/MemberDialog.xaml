<ContentDialog
    x:Class="Hackathon_Project_DavidCaballero.MemberDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Member"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <ScrollViewer>
        <StackPanel Spacing="10" Padding="4">

            <TextBox x:Name="txtFirstName" Header="First Name" />
            <TextBox x:Name="txtMiddleName" Header="Middle Name (optional)" />
            <TextBox x:Name="txtLastName" Header="Last Name" />
            <TextBox x:Name="txtMemberCode" Header="Member Code" />

            <DatePicker x:Name="dpDOB" Header="DOB" />

            <TextBox x:Name="txtOrganization" Header="Organization" />

            <ComboBox x:Name="cmbCategory" Header="Category (A/J)">
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="J"/>
            </ComboBox>

            <Slider x:Name="nbSkillRating" 
                    Header="Skill Rating" 
                    Minimum="1" 
                    Maximum="10" 
                    StepFrequency="1"/>
            <TextBox x:Name="nbYearsExp" 
                     Header="Years Experience" 
                     InputScope="Number"/>

            <ComboBox x:Name="cmbRegion" Header="Region"
                      DisplayMemberPath="Summary"/>

            <ComboBox x:Name="cmbChallenge" Header="Challenge"
                      DisplayMemberPath="Summary"/>

            <TextBlock x:Name="txtError"
                       Foreground="Red"
                       TextWrapping="WrapWholeWords"
                       Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>